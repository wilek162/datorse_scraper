<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> — Datorsc Admin
  </title>
  <link rel="stylesheet" href="/static/style.css">
  <!-- HTMX: no build step, server-driven interactions -->
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
</head>

<body>
  <nav class="nav">
    <a class="nav-brand" href="/">
      <svg class="nav-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd"
          d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z"
          clip-rule="evenodd" />
      </svg>
      Datorsc Admin
    </a>
    <ul class="nav-links">
      <li><a href="/" class="<%= currentPath === '/' ? 'nav-active' : '' %>">Dashboard</a></li>
      <li><a href="/sources" class="<%= (currentPath || '').startsWith('/sources') ? 'nav-active' : '' %>">Sources</a></li>
      <li><a href="/logs" class="<%= (currentPath || '').startsWith('/logs') ? 'nav-active' : '' %>">Logs</a></li>
      <li><a href="/data" class="<%= (currentPath || '').startsWith('/data') ? 'nav-active' : '' %>">Data</a></li>
      <li><a href="/analytics" class="<%= (currentPath || '').startsWith('/analytics') ? 'nav-active' : '' %>">Analytics</a></li>
      <li><a href="/health" class="<%= (currentPath || '').startsWith('/health') ? 'nav-active' : '' %>">Health</a></li>
      <li><a href="/config/sources" class="<%= (currentPath || '').startsWith('/config') ? 'nav-active' : '' %>">Config</a></li>
    </ul>
  </nav>
  <main class="container">
    <h1 class="page-title">
      <%= title %>
    </h1>
