[
  {
    "id": "amazon_se",
    "type": "api",
    "module": "feeds/amazon.js",
    "enabled": false,
    "schedule": "0 */4 * * *",
    "comment": "Amazon PA API — disabled until PA-API credentials are obtained"
  },
  {
    "id": "awin",
    "type": "feed",
    "module": "feeds/awin.js",
    "enabled": false,
    "schedule": "30 2 * * *",
    "comment": "Awin product feed — daily at 02:30"
  },
  {
    "id": "adtraction",
    "type": "feed",
    "module": "feeds/adtraction.js",
    "enabled": false,
    "schedule": "0 3 * * *",
    "comment": "Adtraction CSV feed — daily at 03:00"
  },
  {
    "id": "webhallen",
    "type": "scraper",
    "module": "scrapers/webhallen.js",
    "enabled": false,
    "schedule": "0 */6 * * *",
    "proxyTier": "standard",
    "renderJs": false,
    "rateLimit": {
      "reqPerMin": 15
    },
    "pageLimit": 3,
    "startUrls": [
      "https://www.webhallen.com/se/category/3980-Stationar-dator",
      "https://www.webhallen.com/se/category/3965-Laptop-Barbar-dator"
    ],
    "comment": "Webhallen.se — every 6 hours; plain HTML, no JS render needed"
  },
  {
    "id": "prisjakt",
    "type": "scraper",
    "module": "scrapers/prisjakt.js",
    "enabled": true,
    "schedule": "0 4 * * *",
    "proxyTier": "standard",
    "renderJs": true,
    "rateLimit": {
      "reqPerMin": 10
    },
    "pageLimit": 2,
    "startUrls": [
      "https://www.prisjakt.nu/search?category=352",
      "https://www.prisjakt.nu/search?category=353"
    ],
    "comment": "Prisjakt.nu — daily; supplementary price + EAN data"
  },
  {
    "id": "inet",
    "type": "scraper",
    "module": "scrapers/inet.js",
    "enabled": false,
    "schedule": "20 */4 * * *",
    "proxyTier": "standard",
    "renderJs": true,
    "waitSelector": ".product-list-item",
    "customWait": 1500,
    "rateLimit": {
      "reqPerMin": 12
    },
    "pageLimit": 3,
    "startUrls": [
      "https://www.inet.se/kategori/67/laptop"
    ],
    "comment": "Inet.se — React SPA; requires JS render"
  },
  {
    "id": "komplett",
    "type": "scraper",
    "module": "scrapers/komplett.js",
    "enabled": false,
    "schedule": "10 */4 * * *",
    "proxyTier": "asp",
    "renderJs": true,
    "useZyteAiExtraction": true,
    "rateLimit": {
      "reqPerMin": 10
    },
    "pageLimit": 2,
    "startUrls": [
      "https://www.komplett.se/category/11177/laptops"
    ],
    "comment": "Komplett.se — Cloudflare; disabled until Zyte budget confirmed"
  },
  {
    "id": "elgiganten",
    "type": "scraper",
    "module": "scrapers/elgiganten.js",
    "enabled": true,
    "schedule": "40 */6 * * *",
    "proxyTier": "asp",
    "renderJs": true,
    "useZyteAiExtraction": true,
    "rateLimit": {
      "reqPerMin": 8
    },
    "pageLimit": 2,
    "startUrls": [
      "https://www.elgiganten.se/datorer-kontor/datorer/laptop/windows-laptop",
      "https://www.elgiganten.se/gaming/gaming-pc/gaming-laptop"
    ],
    "comment": "Elgiganten.se — Akamai; disabled until Zyte budget confirmed. Category URLs updated 2026-04."
  }
]