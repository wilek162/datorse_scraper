# ─── Database ───────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=dsc_user
DB_PASSWORD=CHANGE_ME
DB_NAME=datorsc

# ─── Proxy services ──────────────────────────────────────────────────────────────
SCRAPE_DO_TOKEN=YOUR_SCRAPE_DO_TOKEN
ZYTE_API_KEY=YOUR_ZYTE_API_KEY

# ─── Amazon PA-API 5.0 ──────────────────────────────────────────────────────────
AMAZON_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
AMAZON_SECRET_KEY=YOUR_AWS_SECRET_KEY
AMAZON_PARTNER_TAG=YOUR_ASSOCIATE_TAG-21
AMAZON_HOST=webservices.amazon.se
AMAZON_REGION=eu-west-1

# ─── Affiliate feeds ────────────────────────────────────────────────────────────
AWIN_API_KEY=YOUR_AWIN_API_KEY
AWIN_PUBLISHER_ID=YOUR_AWIN_PUBLISHER_ID
ADTRACTION_API_KEY=YOUR_ADTRACTION_API_KEY
ADTRACTION_CHANNEL_ID=YOUR_CHANNEL_ID

# ─── Alerting ────────────────────────────────────────────────────────────────────
ALERT_EMAIL_FROM=noreply@dator.se
ALERT_EMAIL_TO=admin@dator.se
SMTP_HOST=localhost
SMTP_PORT=25

# ─── Runtime ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
# Budget cap: max credits per source per run (hard stop to prevent runaway cost)
PROXY_BUDGET_CAP_SCRAPE_DO=500
PROXY_BUDGET_CAP_ZYTE=200
# Optional: per-credit cost estimates for scrape log cost reporting
SCRAPE_DO_COST_PER_CREDIT_USD=
ZYTE_COST_PER_CREDIT_USD=
