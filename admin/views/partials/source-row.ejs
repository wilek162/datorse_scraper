<!-- Partial: a single <tr> for one source. Used by sources.ejs and HTMX swap. -->
<tr id="source-row-<%= row.id %>">
  <td><strong>
      <%= row.id %>
    </strong></td>
  <td><span class="badge badge-type">
      <%= row.type %>
    </span></td>
  <td><code><%= row.schedule %></code></td>
  <td>
    <% if (row.enabled) { %>
      <span class="badge badge-ok">yes</span>
      <% } else { %>
        <span class="badge badge-disabled">no</span>
        <% } %>
  </td>
  <td>
    <% if (row.paused) { %>
      <span class="badge badge-paused">paused</span>
      <% } else { %>
        <span class="badge badge-ok">active</span>
        <% } %>
  </td>
  <td>
    <% if (row.lastRun) { %>
      <time>
        <%= new Date(row.lastRun.started_at).toLocaleString('sv-SE') %>
      </time>
      <% } else { %>
        <em>never</em>
        <% } %>
  </td>
  <td>
    <% if (row.lastRun) { %>
      <span class="badge badge-<%= row.lastRun.status %>">
        <%= row.lastRun.status %>
      </span>
      <% } else { %>
        <span class="badge badge-disabled">—</span>
        <% } %>
  </td>
  <td class="actions">
    <!-- Toggle pause/resume — HTMX swaps just this row -->
    <button class="btn btn-sm" hx-post="/sources/<%= row.id %>/toggle" hx-target="#source-row-<%= row.id %>"
      hx-swap="outerHTML" hx-confirm="<%= row.paused ? 'Resume' : 'Pause' %> <%= row.id %>?">
      <%= row.paused ? '▶ Resume' : '⏸ Pause' %>
    </button>

    <!-- Trigger immediate run — HTMX shows inline feedback -->
    <button class="btn btn-sm btn-run" hx-post="/sources/<%= row.id %>/run" hx-target="#run-result-<%= row.id %>"
      hx-swap="innerHTML" hx-indicator="#run-spinner-<%= row.id %>">
      ▶ Run now
    </button>
    <span class="htmx-indicator spinner" id="run-spinner-<%= row.id %>">…</span>
    <span id="run-result-<%= row.id %>"></span>

    <a class="btn btn-sm" href="/logs?source=<%= row.id %>">Logs</a>
  </td>
</tr>